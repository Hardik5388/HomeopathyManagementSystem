@model Homeopathy.Web.Areas.Admin.ViewModels.Clinic.ClinicCreateViewModel

<div class="card mb-4">

    <div class="card-header">
        <h5 class="mb-0">Basic Information</h5>
    </div>

    <div class="card-body">

        <div class="row g-3">

            <div class="col-md-6">
                <label asp-for="ClinicCode" class="form-label"></label>
                <input asp-for="ClinicCode" class="form-control" />
                <span asp-validation-for="ClinicCode" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="RegistrationNumber" class="form-label"></label>
                <input asp-for="RegistrationNumber" class="form-control" />
                <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="IsActive" class="form-label d-block"></label>

                <div class="form-check form-switch mt-2">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label">
                        Active
                    </label>
                </div>

            </div>

        </div>

    </div>

</div>
<div class="card mb-4">

    <div class="card-header">
        <h5 class="mb-0">Contact Information</h5>
    </div>

    <div class="card-body">

        <div class="row g-3">

            <div class="col-md-6">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="Website"></label>
                <input asp-for="Website" class="form-control" />
                <span asp-validation-for="Website" class="text-danger"></span>
            </div>

        </div>

    </div>

</div>
<div class="card mb-4">

    <div class="card-header">
        <h5 class="mb-0">Address Information</h5>
    </div>

    <div class="card-body">

        <div class="row g-3">

            <div class="col-12">
                <label asp-for="AddressLine1"></label>
                <input asp-for="AddressLine1" class="form-control" />
            </div>

            <div class="col-12">
                <label asp-for="AddressLine2"></label>
                <input asp-for="AddressLine2" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="City"></label>
                <input asp-for="City" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="State"></label>
                <input asp-for="State" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="Country"></label>
                <input asp-for="Country" class="form-control" />
            </div>

            <div class="col-md-6">
                <label asp-for="PostalCode"></label>
                <input asp-for="PostalCode" class="form-control" />
            </div>

        </div>

    </div>

</div>
<div class="card mb-4">

    <div class="card-header">
        <h5 class="mb-0">Clinic Logo</h5>
    </div>

    <div class="card-body">

        <label asp-for="Logo"></label>

        <input asp-for="Logo" type="file" class="form-control" />

        <span asp-validation-for="Logo" class="text-danger"></span>

    </div>

</div>